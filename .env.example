# Neon Postgres
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.aws.neon.tech/duohub?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.aws.neon.tech/duohub?sslmode=require

# Resend
RESEND_API_KEY=re_xxxxxxxxx
INTERNAL_CONTACT_EMAIL=contato@duohubcontabil.com.br

# Upstash Redis
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxx

# Site (optional — overrides the auto-detected URL from Vercel env vars.
# Used for SEO artefacts like JSON-LD and canonical URLs.)
# NEXT_PUBLIC_SITE_URL=https://duohubcontabil.com.br

# PostHog (product analytics + first-touch attribution).
# The "token" is PostHog's public "Project API Key". Keep the value public-safe;
# it's served to the browser.
NEXT_PUBLIC_POSTHOG_TOKEN=phc_xxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST defaults to "/ingest" (served by a Next.js rewrite to
# https://us.i.posthog.com — bypasses most tracking blockers). Only override if
# you know you need a different region (e.g. "https://eu.i.posthog.com").
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Better Auth (F1a)
BETTER_AUTH_SECRET=  # generate with: openssl rand -hex 32
BETTER_AUTH_URL=http://localhost:3000

# Initial admin seed (F1a, optional — only used by `pnpm db:seed:admin`)
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_NAME=
