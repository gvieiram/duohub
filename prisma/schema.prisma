generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id         String           @id @default(cuid())
  name       String
  email      String           @unique
  whatsapp   String
  service    ContactService   @default(IRPF)
  situation  IrpfSituation?
  complexity IrpfComplexity[]
  moment     IrpfMoment?
  status     ContactStatus    @default(NEW)
  notes      String?
  consentAt  DateTime
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([status])
  @@index([createdAt])
  @@index([service])
}

enum ContactService {
  IRPF
}

enum IrpfSituation {
  CLT
  AUTONOMO
  INVESTIDOR
  MEI
  APOSENTADO
  MULTIPLO
  NAO_SEI
}

enum IrpfComplexity {
  ALUGUEL
  VENDA_IMOVEL
  DEPENDENTES
  RENDA_VARIAVEL
  CRIPTOATIVOS
  EXTERIOR
  PENSAO
  PREVIDENCIA
  NENHUMA
  NAO_SEI
}

enum IrpfMoment {
  PRIMEIRO_ANO
  MALHA_FINA
  JA_DECLAREI
}

enum ContactStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}
