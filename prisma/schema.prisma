generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String           @id @default(cuid())
  name        String
  email       String           @unique
  whatsapp    String
  situation   LeadSituation?
  complexity  LeadComplexity[]
  moment      LeadMoment?
  source      String           @default("ir-page")
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  status      LeadStatus       @default(NEW)
  notes       String?
  consentAt   DateTime
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum LeadSituation {
  CLT
  AUTONOMO
  INVESTIDOR
  MEI
  APOSENTADO
  MULTIPLO
  NAO_SEI
}

enum LeadComplexity {
  ALUGUEL
  VENDA_IMOVEL
  DEPENDENTES
  RENDA_VARIAVEL
  CRIPTOATIVOS
  EXTERIOR
  PENSAO
  PREVIDENCIA
  NENHUMA
  NAO_SEI
}

enum LeadMoment {
  PRIMEIRO_ANO
  MALHA_FINA
  JA_DECLAREI
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}
