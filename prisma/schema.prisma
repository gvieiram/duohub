generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Lead {
  id          String        @id @default(cuid())
  name        String
  email       String        @unique
  whatsapp    String
  situation   LeadSituation
  source      String        @default("ir-page")
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  status      LeadStatus    @default(NEW)
  notes       String?
  consentAt   DateTime
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

enum LeadSituation {
  CLT
  AUTONOMO
  INVESTIDOR
  MEI_COM_PF
  OUTROS
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  WON
  LOST
}
